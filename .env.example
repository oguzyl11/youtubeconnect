# ========== Sunucu (production) ==========
# Sunucuda mutlaka: SECRET_KEY, ALLOWED_HOSTS, BASE_URL gerçek değerlerle doldurulmalı.
# Nginx/Caddy arkasında HTTPS kullanıyorsanız X-Forwarded-Proto: https gönderin.

# Django
SECRET_KEY=your-secret-key-min-50-chars-use-openssl-rand-hex-32
DEBUG=False
# Canlıda kendi domain: .remapsoftware.net,remapsoftware.net vb.
ALLOWED_HOSTS=localhost,127.0.0.1,.yourdomain.com

# Site URL – canlıda mutlaka https ile kendi domain (sonunda / olmasın). Örn: https://remapsoftware.net
BASE_URL=http://localhost:8000

# Docker / sunucu (opsiyonel)
# PORT=8000
# GUNICORN_WORKERS=3

# Lokal (dil ve saat dilimi)
LANGUAGE_CODE=tr-tr
TIME_ZONE=Europe/Istanbul

# Docker Compose - PostgreSQL
POSTGRES_DB=youtubeconnect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database (production: PostgreSQL - docker-compose ile db servisi kullanılıyor)
# DATABASE_URL web servisinde otomatik set edilir
# Local / no DB_URL = SQLite kullanılır

# CORS & CSRF (production'da domain'lerinizi ekleyin)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Transkript: varsayılan yöntem sayfa + timedtext (API anahtarı gerekmez). İsteğe bağlı ScrapingBee:
# SCRAPINGBEE_API_KEY=
# YouTube gibi zor siteler için premium proxy (production'da true önerilir)
SCRAPINGBEE_PREMIUM_PROXY=false
# İstek timeout (ms); varsayılan 90000 (90s; js_scenario için)
# SCRAPINGBEE_TIMEOUT=90000

# Optional: settings module (development/production)
# DJANGO_SETTINGS_MODULE=config.settings.development
# DJANGO_SETTINGS_MODULE=config.settings.production

# FastAPI transcript API – proxy listesi (dönüşümlü, virgülle ayrılmış)
# GitHub'a gerçek şifre koymayın; .env kullanın
YOUTUBE_PROXY_LIST=http://user:pass@ip1:port1,http://user:pass@ip2:port2
