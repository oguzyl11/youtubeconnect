{
  "manifest_version": 3,
  "name": "YouTube Transcript to Remap",
  "version": "1.0",
  "description": "YouTube sayfasından transkripti DOM ile alıp seçtiğiniz siteye gönderir (engellenmez).",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "https://remapsoftware.net/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
