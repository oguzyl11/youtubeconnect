# upstream timed out (110) hatası için: transkript 30–90 sn sürebilir, mutlaka ekleyin.
# proxy_pass portu, uygulamanın dinlediği portla AYNI olmalı (.env PORT=8000 → 8000, PORT=8001 → 8001).

location /api/transcript/ {
    proxy_pass http://127.0.0.1:8000;   # PORT ile aynı olmalı (8000 veya 8001)
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Transkript isteği uzun sürebilir (ScrapingBee/Playwright)
    proxy_connect_timeout 180s;
    proxy_send_timeout 180s;
    proxy_read_timeout 180s;
}
